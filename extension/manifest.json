{
  "manifest_version": 3,
  "name": "LabPass",
  "version": "1.0.0",
  "description": "QR-based quick login/logout for shared university lab computers. Scan to sign in, tap to sign out.",
  "minimum_chrome_version": "116",

  "permissions": [
    "cookies",
    "browsingData",
    "storage",
    "idle",
    "activeTab",
    "alarms"
  ],

  "host_permissions": [
    "*://*.google.com/*",
    "http://localhost:3001/*",
    "https://localhost:3001/*",
    "https://labpass.onrender.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "LabPass — Scan to Login"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
