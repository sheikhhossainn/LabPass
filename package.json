{
  "name": "labpass-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "npx concurrently \"npm run dev:server\" \"npm run dev:pwa\" \"npm run dev:landing\"",
    "dev:landing": "npm --prefix landing run dev",
    "dev:pwa": "npm --prefix pwa run dev",
    "dev:server": "npm --prefix server run dev",
    "dev:ext": "echo 'Load extension manually in chrome://extensions'",
    "start:server": "npm --prefix server run start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "sharp": "^0.35.3"
  }
}
